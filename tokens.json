{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Design tokens for e-conomic Web components - extracted from Figma library",

  "color": {
    "$description": "Color primitives from the e-conomic design system",

    "blue": {
      "100": {
        "$value": "#DEEBFF",
        "$type": "color",
        "$description": "Blue lightest - used for Ghost button hover/active backgrounds"
      },
      "500": {
        "$value": "#4573D2",
        "$type": "color",
        "$description": "Primary blue - main brand color, primary buttons, links, focus rings"
      },
      "700": {
        "$value": "#2B57B4",
        "$type": "color",
        "$description": "Blue dark - used for hover states on primary/ghost/discrete elements"
      }
    },

    "red": {
      "500": {
        "$value": "#CE3F42",
        "$type": "color",
        "$description": "Red - danger/destructive actions"
      },
      "700": {
        "$value": "#950027",
        "$type": "color",
        "$description": "Red dark - danger hover state"
      }
    },

    "grey": {
      "white": {
        "$value": "#FFFFFF",
        "$type": "color",
        "$description": "White background"
      },
      "100": {
        "$value": "#F5F5F5",
        "$type": "color",
        "$description": "Light grey - subtle backgrounds"
      },
      "200": {
        "$value": "#EBEBEB",
        "$type": "color",
        "$description": "Grey - default button background"
      },
      "300": {
        "$value": "#DDDDDD",
        "$type": "color",
        "$description": "Grey dark - default button hover background, input borders"
      },
      "500": {
        "$value": "#ACACAC",
        "$type": "color",
        "$description": "Grey darker - placeholder text, input hover borders"
      },
      "700": {
        "$value": "#595959",
        "$type": "color",
        "$description": "Grey darkest - helper text, secondary text"
      },
      "900": {
        "$value": "#1C1C1C",
        "$type": "color",
        "$description": "Black - primary text color"
      }
    },

    "green": {
      "500": {
        "$value": "#5A9A5A",
        "$type": "color",
        "$description": "Green - success states, positive tags"
      }
    },

    "yellow": {
      "100": {
        "$value": "#FFF1C3",
        "$type": "color",
        "$description": "Yellow lightest - highlighted/modified field background"
      },
      "500": {
        "$value": "#E5A100",
        "$type": "color",
        "$description": "Yellow - warning states, caution tags"
      }
    },

    "purple": {
      "500": {
        "$value": "#7B61FF",
        "$type": "color",
        "$description": "Purple - used for tags and accents"
      }
    },

    "chart": {
      "$description": "Chart visualization colors used in dashboard components",
      "blue": {
        "$value": "#75A0F5",
        "$type": "color",
        "$description": "Chart blue - primary series color for bar, line, area, donut charts"
      },
      "green": {
        "$value": "#52C7AB",
        "$type": "color",
        "$description": "Chart green - secondary series, positive values in area charts"
      },
      "yellow": {
        "$value": "#FFD665",
        "$type": "color",
        "$description": "Chart yellow - tertiary series color"
      },
      "red": {
        "$value": "#E66568",
        "$type": "color",
        "$description": "Chart red - danger series, negative values in area charts"
      },
      "purple": {
        "$value": "#CBBCFE",
        "$type": "color",
        "$description": "Chart purple - additional series color"
      },
      "pink": {
        "$value": "#F98EDB",
        "$type": "color",
        "$description": "Chart pink - additional series color"
      },
      "brown": {
        "$value": "#C4AB9E",
        "$type": "color",
        "$description": "Chart brown - additional series color"
      },
      "orange": {
        "$value": "#FAB64D",
        "$type": "color",
        "$description": "Chart orange - additional series color"
      },
      "grey": {
        "$value": "#DDDDDD",
        "$type": "color",
        "$description": "Chart grey - donut remainder, grid lines"
      },
      "darkBlue": {
        "$value": "#4573D2",
        "$type": "color",
        "$description": "Chart dark blue - used in donut charts and table type indicators"
      }
    }
  },

  "semantic": {
    "$description": "Semantic color tokens that reference primitives",

    "background": {
      "default": {
        "$value": "{color.grey.white}",
        "$type": "color",
        "$description": "Default page/card background"
      },
      "subtle": {
        "$value": "{color.grey.100}",
        "$type": "color",
        "$description": "Subtle background for sections"
      },
      "muted": {
        "$value": "{color.grey.200}",
        "$type": "color",
        "$description": "Muted background - default button bg"
      }
    },
    "foreground": {
      "default": {
        "$value": "{color.grey.900}",
        "$type": "color",
        "$description": "Primary text color"
      },
      "onPrimary": {
        "$value": "{color.grey.white}",
        "$type": "color",
        "$description": "Text on primary/danger colored backgrounds"
      },
      "brand": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Brand-colored text (ghost/discrete buttons, links)"
      }
    },
    "border": {
      "default": {
        "$value": "{color.grey.300}",
        "$type": "color",
        "$description": "Default border color"
      },
      "brand": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Brand border - ghost buttons, focus rings"
      }
    },
    "focus": {
      "ring": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Focus ring color for all interactive elements"
      }
    },
    "state": {
      "error": {
        "$value": "{color.red.500}",
        "$type": "color",
        "$description": "Error/danger state color"
      },
      "success": {
        "$value": "{color.green.500}",
        "$type": "color",
        "$description": "Success state color"
      },
      "warning": {
        "$value": "{color.yellow.500}",
        "$type": "color",
        "$description": "Warning state color"
      }
    }
  },

  "typography": {
    "$description": "Typography tokens - e-conomic uses Helvetica as the primary font",

    "fontFamily": {
      "base": {
        "$value": "Helvetica, Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary font family"
      }
    },

    "fontSize": {
      "xs": {
        "$value": "11px",
        "$type": "dimension",
        "$description": "Extra small text"
      },
      "sm": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Small text - labels, captions"
      },
      "base": {
        "$value": "14px",
        "$type": "dimension",
        "$description": "Base body text size - used in buttons, inputs, body copy"
      },
      "lg": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Large text"
      },
      "xl": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Extra large text - headings"
      },
      "2xl": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Page headings"
      }
    },

    "lineHeight": {
      "tight": {
        "$value": "16px",
        "$type": "dimension"
      },
      "base": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Standard line height for 14px body text"
      },
      "relaxed": {
        "$value": "24px",
        "$type": "dimension"
      }
    },

    "fontWeight": {
      "regular": {
        "$value": 400,
        "$type": "number",
        "$description": "Regular weight - body text, buttons"
      },
      "medium": {
        "$value": 500,
        "$type": "number"
      },
      "bold": {
        "$value": 700,
        "$type": "number",
        "$description": "Bold weight - headings, emphasis"
      }
    },

    "body": {
      "$value": {
        "fontFamily": "Helvetica, Arial, sans-serif",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": "20px",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Standard body text style - used across buttons, inputs, and body copy"
    }
  },

  "spacing": {
    "$description": "Spacing scale tokens - based on Adesy Design Tokens naming convention",

    "null": {
      "$value": "0px",
      "$type": "dimension"
    },
    "xxs": {
      "$value": "2px",
      "$type": "dimension"
    },
    "xs": {
      "$value": "4px",
      "$type": "dimension",
      "$description": "Smallest gap - icon-to-text gap in buttons"
    },
    "s": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Small spacing - tight padding, small gaps"
    },
    "m": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Medium spacing - button horizontal padding"
    },
    "l": {
      "$value": "16px",
      "$type": "dimension",
      "$description": "Large spacing - standard component padding"
    },
    "xl": {
      "$value": "20px",
      "$type": "dimension"
    },
    "xxl": {
      "$value": "24px",
      "$type": "dimension",
      "$description": "Form group spacing"
    },
    "xxxl": {
      "$value": "32px",
      "$type": "dimension"
    },
    "4xl": {
      "$value": "40px",
      "$type": "dimension"
    },
    "5xl": {
      "$value": "48px",
      "$type": "dimension"
    },
    "6xl": {
      "$value": "64px",
      "$type": "dimension"
    },
    "7xl": {
      "$value": "80px",
      "$type": "dimension"
    }
  },

  "borderRadius": {
    "$description": "Border radius tokens",

    "sm": {
      "$value": "2px",
      "$type": "dimension"
    },
    "base": {
      "$value": "4px",
      "$type": "dimension",
      "$description": "Standard border radius for buttons, inputs, cards"
    },
    "md": {
      "$value": "6px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "8px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Chart card border radius"
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Fully rounded - pills, avatars"
    }
  },

  "borderWidth": {
    "default": {
      "$value": "1px",
      "$type": "dimension",
      "$description": "Standard border - ghost buttons, inputs"
    },
    "focus": {
      "$value": "2px",
      "$type": "dimension",
      "$description": "Focus ring border width"
    }
  },

  "sizing": {
    "$description": "Component sizing tokens",

    "icon": {
      "sm": {
        "$value": "16px",
        "$type": "dimension"
      },
      "base": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Icon size inside buttons"
      },
      "lg": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Standalone icon size"
      }
    },

    "button": {
      "height": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Standard button height (6px top + 20px line-height + 6px bottom)"
      },
      "paddingX": {
        "$value": "12px",
        "$type": "dimension"
      },
      "paddingY": {
        "$value": "6px",
        "$type": "dimension"
      },
      "iconPaddingOuter": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Padding on the text side when icon is present"
      },
      "iconPaddingInner": {
        "$value": "8px",
        "$type": "dimension",
        "$description": "Padding on the icon side"
      },
      "gap": {
        "$value": "4px",
        "$type": "dimension",
        "$description": "Gap between icon and text in buttons"
      }
    },

    "input": {
      "height": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Standard input field height"
      }
    }
  },

  "opacity": {
    "disabled": {
      "$value": 0.5,
      "$type": "number",
      "$description": "Opacity for disabled states across all components"
    }
  }
}
