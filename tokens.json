{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Design tokens for e-conomic Web components - extracted from Figma library",

  "color": {
    "$description": "Color primitives from the e-conomic design system (source: Storybook Foundations/Colors)",

    "blue": {
      "100": { "$value": "#DEEBFF", "$type": "color", "$description": "Background hover color for ghost buttons, listbox items" },
      "200": { "$value": "#AACCFF", "$type": "color" },
      "300": { "$value": "#75A0F5", "$type": "color", "$description": "Hover state on blue backgrounds" },
      "500": { "$value": "#4573D2", "$type": "color", "$description": "Primary action color — buttons, badges, labels, links, icons" },
      "700": { "$value": "#2B57B4", "$type": "color", "$description": "Active/focus state on blue backgrounds" },
      "900": { "$value": "#29283E", "$type": "color" }
    },

    "green": {
      "100": { "$value": "#CDF0E7", "$type": "color" },
      "200": { "$value": "#9BE1CE", "$type": "color" },
      "300": { "$value": "#52C7AB", "$type": "color" },
      "500": { "$value": "#08AE87", "$type": "color", "$description": "Success badges — normal, outlined and compact" },
      "700": { "$value": "#028465", "$type": "color" },
      "900": { "$value": "#14493A", "$type": "color" }
    },

    "yellow": {
      "100": { "$value": "#FFF1C3", "$type": "color", "$description": "Highlighted/modified field background" },
      "200": { "$value": "#FFE494", "$type": "color" },
      "300": { "$value": "#FFD665", "$type": "color" },
      "500": { "$value": "#FFBD3B", "$type": "color", "$description": "Warning badges — normal, outlined and compact" },
      "700": { "$value": "#E89C2E", "$type": "color" },
      "900": { "$value": "#733700", "$type": "color" }
    },

    "orange": {
      "100": { "$value": "#FFE3BB", "$type": "color" },
      "200": { "$value": "#FCCB80", "$type": "color" },
      "300": { "$value": "#FAB64D", "$type": "color" },
      "500": { "$value": "#F99702", "$type": "color" },
      "700": { "$value": "#EF7D00", "$type": "color" },
      "900": { "$value": "#4A2811", "$type": "color" }
    },

    "red": {
      "100": { "$value": "#FFDAD2", "$type": "color" },
      "200": { "$value": "#F3A09D", "$type": "color" },
      "300": { "$value": "#E66568", "$type": "color", "$description": "Hover state on red/danger buttons" },
      "500": { "$value": "#CE3F42", "$type": "color", "$description": "Error/danger badges and danger button background" },
      "700": { "$value": "#950027", "$type": "color", "$description": "Active/focus state on red backgrounds" },
      "900": { "$value": "#64001B", "$type": "color" }
    },

    "pink": {
      "100": { "$value": "#FFE3F7", "$type": "color" },
      "200": { "$value": "#FCB9E9", "$type": "color" },
      "300": { "$value": "#F98EDB", "$type": "color" },
      "500": { "$value": "#E165BF", "$type": "color" },
      "700": { "$value": "#CF49AA", "$type": "color" },
      "900": { "$value": "#870062", "$type": "color" }
    },

    "purple": {
      "$description": "Purple number scale (for tags/accents) + navigation purples (for top nav bar)",
      "100": { "$value": "#EEE5FF", "$type": "color" },
      "200": { "$value": "#DDD1FF", "$type": "color" },
      "300": { "$value": "#CBBCFE", "$type": "color" },
      "500": { "$value": "#9270FA", "$type": "color", "$description": "Purple — overlays and illustration accents" },
      "700": { "$value": "#6542D1", "$type": "color" },
      "900": { "$value": "#412970", "$type": "color" },
      "nav": {
        "$description": "Navigation purple palette — used in the top navigation bar",
        "dark": { "$value": "#353A48", "$type": "color", "$description": "Secondary color for top nav bar" },
        "base": { "$value": "#3D4153", "$type": "color", "$description": "Primary top nav bar background" },
        "light": { "$value": "#4B4F64", "$type": "color", "$description": "Search bar and menu icon backgrounds" },
        "lightest": { "$value": "#585C74", "$type": "color", "$description": "Menu icon hover state" }
      }
    },

    "brown": {
      "100": { "$value": "#EEE0DA", "$type": "color" },
      "200": { "$value": "#DFCCC2", "$type": "color" },
      "300": { "$value": "#C4AB9E", "$type": "color" },
      "500": { "$value": "#93715D", "$type": "color" },
      "700": { "$value": "#73503B", "$type": "color" },
      "900": { "$value": "#45291F", "$type": "color" }
    },

    "grey": {
      "white": { "$value": "#FFFFFF", "$type": "color", "$description": "Primary background color" },
      "50": { "$value": "#FAFAFA", "$type": "color", "$description": "Hover color for table rows" },
      "100": { "$value": "#F6F6F6", "$type": "color", "$description": "Navigation background, default button bg, disabled input border" },
      "200": { "$value": "#EBEBEB", "$type": "color", "$description": "Hover/active default button bg, default badge, input field borders" },
      "300": { "$value": "#DDDDDD", "$type": "color", "$description": "Disabled text, borders on grey bg, toggle/progress bg, nav active/hover" },
      "500": { "$value": "#ACACAC", "$type": "color", "$description": "Default border for fields and checkboxes" },
      "700": { "$value": "#595959", "$type": "color", "$description": "Secondary text, placeholder text, discrete icon hover" },
      "900": { "$value": "#303030", "$type": "color" },
      "black": { "$value": "#1C1C1C", "$type": "color", "$description": "Primary text — headings, labels, body, icons" }
    },

    "brand": {
      "$description": "Brand identity colors",
      "coolBlue": { "$value": "#F5F7F9", "$type": "color" },
      "midnightBlue": { "$value": "#29283E", "$type": "color", "$description": "Top navigation bar background" },
      "sunsetOrange": { "$value": "#E89C2E", "$type": "color" },
      "paleOrange": { "$value": "#FFF5E5", "$type": "color" },
      "vismaRed": { "$value": "#E70641", "$type": "color" }
    },

    "chart": {
      "$description": "Chart visualization colors — maps to 300-level palette colors",
      "blue": { "$value": "#75A0F5", "$type": "color", "$description": "Primary series (= blue-300)" },
      "green": { "$value": "#52C7AB", "$type": "color", "$description": "Secondary series (= green-300)" },
      "yellow": { "$value": "#FFD665", "$type": "color", "$description": "Tertiary series (= yellow-300)" },
      "red": { "$value": "#E66568", "$type": "color", "$description": "Danger series (= red-300)" },
      "purple": { "$value": "#CBBCFE", "$type": "color", "$description": "Additional series (= purple-300)" },
      "pink": { "$value": "#F98EDB", "$type": "color", "$description": "Additional series (= pink-300)" },
      "brown": { "$value": "#C4AB9E", "$type": "color", "$description": "Additional series (= brown-300)" },
      "orange": { "$value": "#FAB64D", "$type": "color", "$description": "Additional series (= orange-300)" },
      "grey": { "$value": "#DDDDDD", "$type": "color", "$description": "Donut remainder, grid lines" },
      "darkBlue": { "$value": "#4573D2", "$type": "color", "$description": "Donut charts, table type indicators (= blue-500)" }
    }
  },

  "semantic": {
    "$description": "Semantic color tokens that reference primitives",

    "background": {
      "default": {
        "$value": "{color.grey.white}",
        "$type": "color",
        "$description": "Default page/card background"
      },
      "subtle": {
        "$value": "{color.grey.100}",
        "$type": "color",
        "$description": "Subtle background for sections"
      },
      "muted": {
        "$value": "{color.grey.200}",
        "$type": "color",
        "$description": "Muted background - default button bg"
      }
    },
    "foreground": {
      "default": {
        "$value": "{color.grey.black}",
        "$type": "color",
        "$description": "Primary text color (#1C1C1C)"
      },
      "onPrimary": {
        "$value": "{color.grey.white}",
        "$type": "color",
        "$description": "Text on primary/danger colored backgrounds"
      },
      "brand": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Brand-colored text (ghost/discrete buttons, links)"
      }
    },
    "border": {
      "default": {
        "$value": "{color.grey.300}",
        "$type": "color",
        "$description": "Default border color"
      },
      "brand": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Brand border - ghost buttons, focus rings"
      }
    },
    "focus": {
      "ring": {
        "$value": "{color.blue.500}",
        "$type": "color",
        "$description": "Focus ring color for all interactive elements"
      }
    },
    "state": {
      "error": {
        "$value": "{color.red.500}",
        "$type": "color",
        "$description": "Error/danger state color"
      },
      "success": {
        "$value": "{color.green.500}",
        "$type": "color",
        "$description": "Success state color"
      },
      "warning": {
        "$value": "{color.yellow.500}",
        "$type": "color",
        "$description": "Warning state color"
      }
    }
  },

  "typography": {
    "$description": "Typography tokens - e-conomic uses Helvetica as the primary font",

    "fontFamily": {
      "base": {
        "$value": "Helvetica, Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary font family"
      }
    },

    "fontSize": {
      "xs": {
        "$value": "11px",
        "$type": "dimension",
        "$description": "Extra small text"
      },
      "sm": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Small text - labels, captions"
      },
      "base": {
        "$value": "14px",
        "$type": "dimension",
        "$description": "Base body text size - used in buttons, inputs, body copy"
      },
      "lg": {
        "$value": "16px",
        "$type": "dimension",
        "$description": "Large text"
      },
      "xl": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Extra large text - headings"
      },
      "2xl": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Page headings"
      }
    },

    "lineHeight": {
      "tight": {
        "$value": "16px",
        "$type": "dimension"
      },
      "base": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Standard line height for 14px body text"
      },
      "relaxed": {
        "$value": "24px",
        "$type": "dimension"
      }
    },

    "fontWeight": {
      "regular": {
        "$value": 400,
        "$type": "number",
        "$description": "Regular weight - body text, buttons"
      },
      "medium": {
        "$value": 500,
        "$type": "number"
      },
      "bold": {
        "$value": 700,
        "$type": "number",
        "$description": "Bold weight - headings, emphasis"
      }
    },

    "body": {
      "$value": {
        "fontFamily": "Helvetica, Arial, sans-serif",
        "fontWeight": 400,
        "fontSize": "14px",
        "lineHeight": "20px",
        "letterSpacing": "0"
      },
      "$type": "typography",
      "$description": "Standard body text style - used across buttons, inputs, and body copy"
    }
  },

  "spacing": {
    "$description": "Full spacing scale from Figma stylesheet — maps to Tailwind spacing utilities. Named tokens (xxs–7xl) are the most commonly used in the design system.",

    "0": { "$value": "0px", "$type": "dimension" },
    "px": { "$value": "1px", "$type": "dimension", "$description": "1px - fine borders, hairlines" },
    "0.5": { "$value": "2px", "$type": "dimension", "$description": "Also named 'xxs'" },
    "1": { "$value": "4px", "$type": "dimension", "$description": "Also named 'xs' - icon-to-text gap in buttons" },
    "1.5": { "$value": "6px", "$type": "dimension", "$description": "Button vertical padding" },
    "2": { "$value": "8px", "$type": "dimension", "$description": "Also named 's' - tight padding, small gaps" },
    "2.5": { "$value": "10px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension", "$description": "Also named 'm' - button horizontal padding" },
    "3.5": { "$value": "14px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension", "$description": "Also named 'l' - standard component padding" },
    "5": { "$value": "20px", "$type": "dimension", "$description": "Also named 'xl'" },
    "6": { "$value": "24px", "$type": "dimension", "$description": "Also named 'xxl' - form group spacing" },
    "7": { "$value": "28px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension", "$description": "Also named 'xxxl'" },
    "9": { "$value": "36px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension", "$description": "Also named '4xl'" },
    "11": { "$value": "44px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension", "$description": "Also named '5xl'" },
    "14": { "$value": "56px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension", "$description": "Also named '6xl'" },
    "20": { "$value": "80px", "$type": "dimension", "$description": "Also named '7xl'" },
    "24": { "$value": "96px", "$type": "dimension" },
    "28": { "$value": "112px", "$type": "dimension" },
    "32": { "$value": "128px", "$type": "dimension" },
    "36": { "$value": "144px", "$type": "dimension" },
    "40": { "$value": "160px", "$type": "dimension" },
    "44": { "$value": "176px", "$type": "dimension" },
    "48": { "$value": "192px", "$type": "dimension" },
    "52": { "$value": "208px", "$type": "dimension" },
    "56": { "$value": "224px", "$type": "dimension" },
    "60": { "$value": "240px", "$type": "dimension" },
    "64": { "$value": "256px", "$type": "dimension" },
    "72": { "$value": "288px", "$type": "dimension" },
    "80": { "$value": "320px", "$type": "dimension" },
    "96": { "$value": "384px", "$type": "dimension" }
  },

  "borderRadius": {
    "$description": "Border radius tokens",

    "sm": {
      "$value": "2px",
      "$type": "dimension"
    },
    "base": {
      "$value": "4px",
      "$type": "dimension",
      "$description": "Standard border radius for buttons, inputs, cards"
    },
    "md": {
      "$value": "6px",
      "$type": "dimension"
    },
    "lg": {
      "$value": "8px",
      "$type": "dimension"
    },
    "xl": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Chart card border radius"
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "$description": "Fully rounded - pills, avatars"
    }
  },

  "borderWidth": {
    "default": {
      "$value": "1px",
      "$type": "dimension",
      "$description": "Standard border - ghost buttons, inputs"
    },
    "focus": {
      "$value": "2px",
      "$type": "dimension",
      "$description": "Focus ring border width"
    }
  },

  "sizing": {
    "$description": "Component sizing tokens",

    "icon": {
      "sm": {
        "$value": "16px",
        "$type": "dimension"
      },
      "base": {
        "$value": "20px",
        "$type": "dimension",
        "$description": "Icon size inside buttons"
      },
      "lg": {
        "$value": "24px",
        "$type": "dimension",
        "$description": "Standalone icon size"
      }
    },

    "button": {
      "height": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Standard button height (6px top + 20px line-height + 6px bottom)"
      },
      "paddingX": {
        "$value": "12px",
        "$type": "dimension"
      },
      "paddingY": {
        "$value": "6px",
        "$type": "dimension"
      },
      "iconPaddingOuter": {
        "$value": "12px",
        "$type": "dimension",
        "$description": "Padding on the text side when icon is present"
      },
      "iconPaddingInner": {
        "$value": "8px",
        "$type": "dimension",
        "$description": "Padding on the icon side"
      },
      "gap": {
        "$value": "4px",
        "$type": "dimension",
        "$description": "Gap between icon and text in buttons"
      }
    },

    "input": {
      "height": {
        "$value": "32px",
        "$type": "dimension",
        "$description": "Standard input field height"
      }
    }
  },

  "border": {
    "$description": "Border and divider tokens using box-shadow technique from Figma stylesheet",

    "divider": {
      "bottom": {
        "$value": "0 1px 0 0 #DDDDDD",
        "$type": "shadow",
        "$description": "Outside bottom border — horizontal divider below an element"
      },
      "right": {
        "$value": "1px 0 0 0 #DDDDDD",
        "$type": "shadow",
        "$description": "Outside right border — vertical divider to the right"
      },
      "left": {
        "$value": "-1px 0 0 0 #DDDDDD",
        "$type": "shadow",
        "$description": "Outside left border — vertical divider to the left"
      },
      "insideBottom": {
        "$value": "inset 0 -1px 0 0 #DDDDDD",
        "$type": "shadow",
        "$description": "Inside bottom border — inset horizontal divider (e.g. table rows, list items)"
      },
      "insideBottom2px": {
        "$value": "inset 0 -2px 0 0 #DDDDDD",
        "$type": "shadow",
        "$description": "Inside bottom border 2px — thicker inset divider (e.g. active tab indicator)"
      }
    }
  },

  "elevation": {
    "$description": "Elevation (shadow) tokens from Figma stylesheet — uses rgba(47,51,68) base color",

    "light": {
      "$description": "Light elevation levels for standard UI surfaces",
      "1": {
        "$value": "0px 1px 2px rgba(47,51,68,0.1), 0px 1px 3px rgba(47,51,68,0.1)",
        "$type": "shadow",
        "$description": "Light E1 — subtle lift, cards at rest"
      },
      "2": {
        "$value": "0px 2px 4px rgba(47,51,68,0.1), 0px 1px 6px rgba(47,51,68,0.1)",
        "$type": "shadow",
        "$description": "Light E2 — slight elevation, hover cards"
      },
      "3": {
        "$value": "0px 1px 2px rgba(47,51,68,0.1), 0px 4px 12px rgba(47,51,68,0.1)",
        "$type": "shadow",
        "$description": "Light E3 — moderate elevation, floating panels"
      },
      "4": {
        "$value": "0px 2px 4px rgba(47,51,68,0.1), 0px 8px 24px rgba(47,51,68,0.1)",
        "$type": "shadow",
        "$description": "Light E4 — high elevation, modals in light context"
      }
    },
    "dark": {
      "$description": "Dark elevation levels for overlays and dropdowns",
      "1": {
        "$value": "0px 1px 2px rgba(47,51,68,0.3), 0px 2px 6px rgba(47,51,68,0.15)",
        "$type": "shadow",
        "$description": "Dark E1 — dropdown menus, tooltips, popovers"
      },
      "2": {
        "$value": "0px 2px 4px rgba(47,51,68,0.3), 0px 4px 12px rgba(47,51,68,0.15)",
        "$type": "shadow",
        "$description": "Dark E2 — elevated dropdown panels"
      },
      "3": {
        "$value": "0px 4px 8px rgba(47,51,68,0.3), 0px 8px 24px rgba(47,51,68,0.15)",
        "$type": "shadow",
        "$description": "Dark E3 — modal dialogs, drawers"
      },
      "4": {
        "$value": "0px 8px 16px rgba(47,51,68,0.3), 0px 16px 48px rgba(47,51,68,0.15)",
        "$type": "shadow",
        "$description": "Dark E4 — highest elevation, full-screen overlays"
      }
    },
    "banner": {
      "$value": "0px 4px 6px rgba(0,0,0,0.1), 0px 10px 15px rgba(0,0,0,0.1)",
      "$type": "shadow",
      "$description": "Banner shadow — sticky headers, notification banners"
    }
  },

  "breakpoint": {
    "$description": "Responsive breakpoint tokens from Figma stylesheet",

    "xs": {
      "$value": "376px",
      "$type": "dimension",
      "$description": "Extra small — mobile portrait"
    },
    "sm": {
      "$value": "640px",
      "$type": "dimension",
      "$description": "Small — large mobile / small tablet"
    },
    "md": {
      "$value": "768px",
      "$type": "dimension",
      "$description": "Medium — tablet portrait"
    },
    "lg": {
      "$value": "1024px",
      "$type": "dimension",
      "$description": "Large — tablet landscape / small desktop"
    },
    "xl": {
      "$value": "1280px",
      "$type": "dimension",
      "$description": "Extra large — standard desktop"
    },
    "2xl": {
      "$value": "1536px",
      "$type": "dimension",
      "$description": "2X large — wide desktop"
    },
    "3xl": {
      "$value": "1920px",
      "$type": "dimension",
      "$description": "3X large — full HD and above"
    }
  },

  "opacity": {
    "disabled": {
      "$value": 0.5,
      "$type": "number",
      "$description": "Opacity for disabled states across all components"
    }
  }
}
